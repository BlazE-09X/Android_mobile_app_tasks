<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Лабораторная работа"
            android:textSize="24sp"
            android:layout_marginBottom="30dp"/>

        <Button android:id="@+id/btnTask1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Анкета студента" />

        <Button android:id="@+id/btnTask2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Фото профиля (Камера)" />

        <Button android:id="@+id/btnTask3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Крестики-нолики" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>